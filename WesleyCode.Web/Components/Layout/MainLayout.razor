@using Microsoft.JSInterop
@using WesleyCode.Web.Services
@inherits LayoutComponentBase
@implements IDisposable
@implements IAsyncDisposable
@inject ChatWorkspaceService Workspace
@inject IJSRuntime JSRuntime

<div class="shell" style="@GetShellStyle()">
    <aside class="sidebar">
        <div class="sidebar-main">
            <div class="brand">
                <div class="brand-mark" aria-hidden="true">W</div>
                <div class="brand-copy">
                    <p class="brand-eyebrow">WesleyCode</p>
                    <p class="brand-name">智能开发工作台</p>
                </div>
            </div>

            <section class="sidebar-section sidebar-status-card">
                <span class="status-indicator @(Workspace.IsBusy ? "busy" : string.Empty)" aria-hidden="true"></span>
                <div>
                    <span class="sidebar-label">运行状态</span>
                    <p>@(Workspace.IsBusy ? "正在处理你的任务" : "已就绪，可以开始")</p>
                </div>
            </section>

            <button class="sidebar-action" @onclick="CreateNewConversationAsync" disabled="@Workspace.IsBusy">
                <span class="action-icon" aria-hidden="true">＋</span>
                <span>新建对话</span>
            </button>

            <a class="sidebar-action sidebar-action-secondary" href="/workspace/archive">
                <span class="action-icon download-icon" aria-hidden="true">↓</span>
                <span>下载工作区</span>
            </a>

            <section class="sidebar-section sidebar-files">
                <div class="sidebar-files-header">
                    <span class="sidebar-label">工作区文件</span>
                    <div class="sidebar-files-tools">
                        <span class="sidebar-files-count">@Workspace.WorkspaceEntries.Count 项</span>
                    </div>
                </div>

                @if (Workspace.WorkspaceEntries.Count == 0)
                {
                    <p class="sidebar-files-empty">当前工作区暂无文件。</p>
                }
                else
                {
                    <div class="sidebar-tree-scroll">
                        <ul class="sidebar-tree" role="tree" aria-label="工作区文件树">
                            @foreach (var entry in Workspace.WorkspaceEntries)
                            {
                                @RenderWorkspaceEntry(entry)
                            }
                        </ul>
                    </div>
                }
            </section>
        </div>

        <div class="sidebar-resizer" @ref="_sidebarResizer" aria-hidden="true"></div>
    </aside>

    <main class="workspace">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    页面发生未处理异常。
    <a href="." class="reload">重新加载</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const double MinSidebarWidth = 260;
    private const double MaxSidebarWidth = 720;
    private double _sidebarWidth = 350;
    private ElementReference _sidebarResizer;
    private IJSObjectReference? _module;
    private DotNetObjectReference<MainLayout>? _selfReference;

    protected override void OnInitialized()
    {
        Workspace.Changed += OnWorkspaceChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/sidebarResize.js");
        _selfReference = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("registerSidebarResize", _sidebarResizer, _selfReference, MinSidebarWidth, MaxSidebarWidth);
    }

    public void Dispose()
    {
        Workspace.Changed -= OnWorkspaceChanged;
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disposeSidebarResize", _sidebarResizer);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _selfReference?.Dispose();
    }

    [JSInvokable]
    public Task UpdateSidebarWidthAsync(double width)
    {
        _sidebarWidth = Math.Clamp(width, MinSidebarWidth, MaxSidebarWidth);
        return InvokeAsync(StateHasChanged);
    }

    private async Task CreateNewConversationAsync()
    {
        await Workspace.CreateNewConversationAsync();
    }

    private void RefreshWorkspaceFiles()
    {
        Workspace.RefreshWorkspaceEntries();
    }

    private async void OnWorkspaceChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private string GetShellStyle() =>
        $"--sidebar-width: {_sidebarWidth}px; --sidebar-min-width: {MinSidebarWidth}px; --sidebar-max-width: {MaxSidebarWidth}px;";

    private RenderFragment RenderWorkspaceEntry(ChatWorkspaceService.WorkspaceEntryNode entry) => builder =>
    {
        if (entry.IsDirectory)
        {
            builder.OpenElement(0, "li");
            builder.AddAttribute(1, "class", "workspace-tree-item");
            builder.AddAttribute(2, "role", "treeitem");
            builder.AddAttribute(3, "aria-expanded", "true");

            builder.OpenElement(4, "details");
            builder.AddAttribute(5, "class", "workspace-tree-group");
            builder.AddAttribute(6, "open", true);

            builder.OpenElement(7, "summary");
            builder.AddAttribute(8, "class", "workspace-tree-summary");
            builder.OpenElement(9, "div");
            builder.AddAttribute(10, "class", "workspace-tree-label");

            builder.OpenElement(11, "span");
            builder.AddAttribute(12, "class", "workspace-tree-icon directory");
            builder.AddAttribute(13, "aria-hidden", "true");
            builder.AddContent(14, "📁");
            builder.CloseElement();

            builder.OpenElement(15, "span");
            builder.AddAttribute(16, "class", "workspace-tree-name directory");
            builder.AddContent(17, entry.Name);
            builder.CloseElement();

            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(18, "ul");
            builder.AddAttribute(19, "class", "workspace-tree-children");
            builder.AddAttribute(20, "role", "group");
            foreach (var child in entry.Children)
            {
                builder.AddContent(21, RenderWorkspaceEntry(child));
            }
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();
            return;
        }

        builder.OpenElement(18, "li");
        builder.AddAttribute(19, "class", "workspace-tree-item workspace-tree-file");
        builder.AddAttribute(20, "role", "treeitem");

        builder.OpenElement(21, "div");
        builder.AddAttribute(22, "class", "workspace-tree-label");

        builder.OpenElement(23, "span");
        builder.AddAttribute(24, "class", "workspace-tree-icon file");
        builder.AddAttribute(25, "aria-hidden", "true");
        builder.AddContent(26, "📄");
        builder.CloseElement();

        builder.OpenElement(27, "span");
        builder.AddAttribute(28, "class", "workspace-tree-name");
        builder.AddContent(29, entry.Name);
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };
}
